<FindBugsFilter>
  <!--
    Socket and IStorage are intentionally stored via constructor injection.
    Defensive copying would break the server's connection handling.
  -->
  <Match>
    <Bug pattern="EI_EXPOSE_REP2"/>
    <Or>
      <Class name="org.valarpirai.redis.server.ClientHandler"/>
      <Class name="org.valarpirai.redis.command.CommandExecutor"/>
      <Class name="org.valarpirai.redis.storage.ExpiryCleanerWorker"/>
    </Or>
  </Match>

  <!--
    Pattern matching switch binds a variable per arm (e.g. case Foo r ->).
    SpotBugs flags unused 'r' as a dead store; this is compiler-required syntax.
  -->
  <Match>
    <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
    <Or>
      <Class name="org.valarpirai.redis.protocol.RespEncoder"/>
      <Class name="org.valarpirai.redis.command.CommandExecutor"/>
    </Or>
  </Match>
</FindBugsFilter>
